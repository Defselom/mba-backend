# Variables de base
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_NAME=my_database

# Test DB
TEST_DB_USER=test_user
TEST_DB_PASSWORD=test_password
TEST_DB_NAME=test_database

# Ports
DEV_DB_PORT=5451
PROD_DB_PORT=5452
TEST_DB_PORT=5453

# URLs composées (utilisant les variables ci-dessus)
DEV_DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DEV_DB_PORT}/${DB_NAME}
PROD_DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${PROD_DB_PORT}/${DB_NAME}
TEST_DATABASE_URL=postgresql://${TEST_DB_USER}:${TEST_DB_PASSWORD}@${DB_HOST}:${TEST_DB_PORT}/${TEST_DB_NAME}
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${PROD_DB_PORT}/${DB_NAME}?sslmode=verify-full

# JWT Secrets
JWT_SECRET="your_jwt_secret"
JWT_REFRESH_SECRET="your_jwt_refresh_secret"

# Environment
NODE_ENV=development
APP_NAME=mba-backend

# Ports applicatifs
DEV_APP_PORT=3000
PROD_APP_PORT=3001


# Frontend URL (pour les liens dans les emails)
FRONTEND_URL=http://localhost:3000

# Email Configuration
EMAIL_DEFAULT_FROM="MBA <no-reply@your-domain.com>"

# Mailgun Configuration
MAILGUN_DOMAIN=your-domain.com
SMTP_PASSWORD=your_smtp_password
MAILGUN_API_KEY=your_mailgun_api_key
# MAILGUN_BASE_URL=https://api.eu.mailgun.net (pour l'EU, optionnel)

# S3 Storage
S3_ACCES_KEY=your_s3_access_key
S3_SECRET_KEY=your_s3_secret_key
S3_ENDPOINT=https://api-s3.your-domain.com
S3_BUCKET_NAME=your_bucket_name
